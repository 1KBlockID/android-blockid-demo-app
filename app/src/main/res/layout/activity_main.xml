<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/txtResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:maxLines="3"
        android:text="Result"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnTenantRegister"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1Kosmos Tenant Register" />

    <Button
        android:id="@+id/btnPasskeyRegister"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1Kosmos Passkey Register" />

    <Button
        android:id="@+id/btnPasskeyAuthenticate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1Kosmos Passkey Authenticate" />

    <Button
        android:id="@+id/btnEncrypt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Encrypt and Save Secure Data" />

    <Button
        android:id="@+id/btnDecrypt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Decrypt Secure Data" />

    <TextView
        android:id="@+id/txtProvider"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Provider"
        android:textSize="16sp" />
</LinearLayout>
